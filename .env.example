# =============================================================================
# Shared Services Decision Intelligence Platform - Environment Configuration
# =============================================================================
# Copy this file to ".env.local" and fill in the values.
# NEVER commit ".env.local" or real keys to version control.
# Sensitive organizational files should ONLY be uploaded once the organization
# has formally approved the selected AI provider and storage configuration.
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider - Anthropic Claude (REQUIRED for real analysis)
# -----------------------------------------------------------------------------
# Obtain a key from https://console.anthropic.com/
# Without this key the platform runs in "demo analysis" mode and clearly labels
# every output as non-AI generated.
ANTHROPIC_API_KEY=
# Model used for executive analysis and reasoning.
ANTHROPIC_MODEL=claude-opus-4-8

# -----------------------------------------------------------------------------
# Embeddings Provider (OPTIONAL - for semantic Knowledge Base retrieval)
# -----------------------------------------------------------------------------
# Options: "local" (default, no external calls) | "openai"
# "local" uses an in-process lexical vectorizer - no data leaves the server.
# "openai" sends Knowledge Base text to OpenAI to compute embeddings.
EMBEDDINGS_PROVIDER=local
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Storage (private, server-side only)
# -----------------------------------------------------------------------------
# Local filesystem directory for uploaded files. Kept private and gitignored.
STORAGE_DIR=./storage/uploads

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local SQLite file for the MVP. The data layer is abstracted so this can be
# swapped for PostgreSQL + pgvector in an enterprise deployment.
DATABASE_URL=./data/app.db

# -----------------------------------------------------------------------------
# Platform
# -----------------------------------------------------------------------------
DEFAULT_LOCALE=ar
MAX_UPLOAD_MB=50
